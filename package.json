{
  "name": "image-task-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "dev:server": "node --watch --experimental-strip-types src/server/index.ts",
    "build": "tsc -p tsconfig.app.json && vite build && vite build --config vite.server.config.ts",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.2.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  }
}
